root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2

[*.{py,pyw,ipynb,js,cjs,mjs,jsx,ts,mts,tsx,cs,cc,cpp,hpp,c,h}]
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{csv,tsv,json,jsonl,xml,yml,yaml,html,css,scss,md}]
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true